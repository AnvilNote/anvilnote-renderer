{
  "slug": "mousse-notes",
  "name": "items.mousse-notes.name",
  "description": "items.mousse-notes.description",
  "version": "0.1.0",
  "engine": {
    "kind": "typst-package",
    "package": "@preview/mousse-notes:1.1.0",
    "entry": "template.typ"
  },
  "category": "note",
  "tags": [
    "book",
    "cover",
    "theorems"
  ],
  "fonts": [
    "New Computer Modern",
    "New Computer Modern Math"
  ],
