      "label": "fields.dateFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "playfair",
      "options": [
        "playfair",
        "tai-heritage"
      ]
    }
  ],
  "usesAnvilFontWrapper": true,
  "supportsNumberedHeadings": false,
  "supportsCustomMargins": false,
  "usesSharedOverrides": true,
  "fontPolicy": "anvil-controlled"
