{
  "slug": "metropole-report",
  "name": "items.metropole-report.name",
  "description": "items.metropole-report.description",
  "version": "0.1.0",
  "engine": {
    "kind": "typst-package",
    "package": "@preview/metropole-report:0.1.0",
    "entry": "template.typ"
  },
  "category": "report",
  "tags": [
    "report",
    "cover",
    "clean"
  ],
  "fonts": [
    "Source Serif 4",
    "Source Sans 3",
    "Source Code Pro"
  ],
  "headingOffset": 0,
  "textWidthCm": 14.21,
  "fields": [
    {
      "key": "title",
      "label": "fields.title",
      "type": "text",
      "scope": "metadata",
      "required": true,
      "default": "Untitled"
    },
    {
      "key": "subtitle",
      "label": "fields.subtitle",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "author",
      "label": "fields.author",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "date",
      "label": "fields.date",
      "type": "date",
      "scope": "metadata",
      "required": false,
      "default": "today"
    },
    {
      "key": "coverPage",
      "label": "fields.coverPage",
      "type": "boolean",
      "scope": "option",
      "required": false,
      "default": false
    },
    {
      "key": "paperSize",
      "label": "fields.paperSize",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "a4",
      "options": [
        "a4",
        "us-letter"
      ]
    },
    {
      "key": "accentColor",
      "label": "fields.accentColor",
      "type": "color",
      "scope": "option",
      "required": false,
      "default": "#c53a2f"
    },
    {
      "key": "mathMode",
      "label": "fields.mathMode",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "default",
      "options": [
        "default",
        "garamond"
      ]
    },
    {
      "key": "primaryLang",
      "label": "fields.primaryLang",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "zh",
      "options": [
        "zh",
        "en",
        "ja",
        "ko",
        "th"
      ]
    },
    {
      "key": "titleFont",
      "label": "fields.titleFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "taiwan-pearl",
      "options": [
        "taiwan-pearl",
        "source-han"
      ]
    },
    {
      "key": "bodyFont",
      "label": "fields.bodyFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "song",
      "options": [
        "song",
        "kai"
      ]
    },
    {
      "key": "dateFont",
      "label": "fields.dateFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "playfair",
      "options": [
        "playfair",
        "tai-heritage"
      ]
    }
  ],
  "usesAnvilFontWrapper": true,
  "fontPolicy": "anvil-controlled"
}
