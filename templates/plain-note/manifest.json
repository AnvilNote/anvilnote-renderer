{
  "slug": "plain-note",
  "name": "items.plain-note.name",
  "description": "items.plain-note.description",
  "version": "0.3.0",
  "engine": {
    "kind": "local",
    "entry": "template.typ"
  },
  "category": "note",
  "tags": [
    "clean",
    "cjk",
    "a4"
  ],
  "fonts": [
    "New Computer Modern",
    "CMU Typewriter Text",
    "Roboto",
    "cwTeX Q Ming",
    "cwTeX Q Yuan",
    "cwTeX Q Hei",
    "Times New Roman"
  ],
  "headingOffset": 1,
  "fields": [
    {
      "key": "title",
      "label": "fields.title",
      "type": "text",
      "scope": "metadata",
      "required": true,
      "default": "Untitled"
    },
    {
      "key": "author",
      "label": "fields.author",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "date",
      "label": "fields.date",
      "type": "date",
      "scope": "metadata",
      "required": false,
      "default": "today"
    },
    {
      "key": "toc",
      "label": "fields.toc",
      "type": "boolean",
      "scope": "option",
      "required": false,
      "default": true
    },
    {
      "key": "colorlinks",
      "label": "fields.colorlinks",
      "type": "boolean",
      "scope": "option",
      "required": false,
      "default": true
    }
  ],
  "usesAnvilFontWrapper": false,
  "fontPolicy": "anvil-controlled"
}
