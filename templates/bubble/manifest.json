{
  "slug": "bubble",
  "name": "items.bubble.name",
  "description": "items.bubble.description",
  "version": "0.2.0",
  "engine": {
    "kind": "typst-package",
    "package": "@preview/bubble:0.2.2",
    "entry": "template.typ"
  },
  "category": "lecture",
  "tags": [
    "colorful",
    "cover",
    "lecture"
  ],
  "fonts": [
    "Source Sans Pro",
    "Barlow"
  ],
  "headingOffset": 0,
  "fields": [
    {
      "key": "title",
      "label": "fields.title",
      "type": "text",
      "scope": "metadata",
      "required": true,
      "default": "Untitled"
    },
    {
      "key": "subtitle",
      "label": "fields.subtitle",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "author",
      "label": "fields.author",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "affiliation",
      "label": "fields.affiliation",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "year",
      "label": "fields.year",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "courseName",
      "label": "fields.courseName",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "mainColor",
      "label": "fields.mainColor",
      "type": "text",
      "scope": "option",
      "required": false,
      "default": "#E94845"
    },
    {
      "key": "mathMode",
      "label": "fields.mathMode",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "default",
      "options": [
        "default",
        "garamond"
      ]
    },
    {
      "key": "primaryLang",
      "label": "fields.primaryLang",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "zh",
      "options": [
        "zh",
        "en",
        "ja",
        "ko",
        "th"
      ]
    },
    {
      "key": "titleFont",
      "label": "fields.titleFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "taiwan-pearl",
      "options": [
        "taiwan-pearl",
        "source-han"
      ]
    },
    {
      "key": "bodyFont",
      "label": "fields.bodyFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "song",
      "options": [
        "song",
        "kai"
      ]
    },
    {
      "key": "dateFont",
      "label": "fields.dateFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "playfair",
      "options": [
        "playfair",
        "tai-heritage"
      ]
    }
  ],
  "usesAnvilFontWrapper": true,
  "fontPolicy": "anvil-controlled"
}
