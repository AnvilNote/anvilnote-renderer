{
  "slug": "obelisk",
  "name": "items.obelisk.name",
  "description": "items.obelisk.description",
  "version": "0.1.0",
  "engine": {
    "kind": "typst-package",
    "package": "@preview/obelisk:0.1.0",
    "entry": "template.typ"
  },
  "category": "note",
  "tags": ["note", "minimal", "sidenotes", "theorems"],
  "fonts": ["TeX Gyre Pagella", "TeX Gyre Pagella Math", "Switzer", "IBM Plex Mono"],
  "headingOffset": 0,
  "fields": [
    {
      "key": "title",
      "label": "fields.title",
      "type": "text",
      "scope": "metadata",
      "required": true,
      "default": "Untitled"
    },
    {
      "key": "author",
      "label": "fields.author",
      "type": "text",
      "scope": "metadata",
      "required": false
    },
    {
      "key": "date",
      "label": "fields.date",
      "type": "date",
      "scope": "metadata",
      "required": false,
      "default": "today"
    },
    {
      "key": "mathMode",
      "label": "fields.mathMode",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "default",
      "options": ["default", "garamond"]
    },
    {
      "key": "primaryLang",
      "label": "fields.primaryLang",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "zh",
      "options": ["zh", "en", "ja", "ko", "th"]
    },
    {
      "key": "titleFont",
      "label": "fields.titleFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "taiwan-pearl",
      "options": ["taiwan-pearl", "source-han"]
    },
    {
      "key": "bodyFont",
      "label": "fields.bodyFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "song",
      "options": ["song", "kai"]
    },
    {
      "key": "dateFont",
      "label": "fields.dateFont",
      "type": "select",
      "scope": "option",
      "required": false,
      "default": "playfair",
      "options": ["playfair", "tai-heritage"]
    }
  ],
  "usesAnvilFontWrapper": true,
  "fontPolicy": "anvil-controlled"
}
