TYPST_BIN=typst

# Directory of the bundled AnvilNote fonts passed to Typst's --font-path.
# Local default is ./fonts; in Docker set this to /app/fonts.
ANVILNOTE_FONT_DIR=./fonts

# Ignore system-installed fonts so renders only use the bundle (default: true).
# Set to false only as a temporary escape hatch while the bundle is incomplete.
ANVILNOTE_IGNORE_SYSTEM_FONTS=true
