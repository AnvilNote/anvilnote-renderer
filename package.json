{
  "name": "anvilnote-renderer",
  "version": "0.1.0",
  "private": true,
  "description": "CLI renderer for AnvilNote Typst PDF generation.",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "render": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "fonts:download": "tsx scripts/download-fonts.ts",
    "fonts:verify": "tsx scripts/verify-fonts.ts",
    "fonts:list": "typst fonts --font-path ./fonts --ignore-system-fonts",
    "templates:lint": "tsx scripts/lint-templates.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "tex2typst": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
